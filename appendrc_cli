#!/bin/bash

# Define the directory where files should be created
export APPENDRC_PATH="${BASH_FILES_DIR}/repos/appendrc"
export APPENDRC_SRC_PATH="${APPENDRC_PATH}/sourcables"

# Define Path Management Files
export APPENDRC_PATH_LIST="${APPENDRC_PATH}/path_list.txt"
export APPENDRC_PATH_SOURCABLE="${APPENDRC_SRC_PATH}/000_appendrc_paths"

# Ensure directories exist immediately
mkdir -p "$APPENDRC_SRC_PATH"

# -----------------------------------------------------------------------------
# Core Functionality: Init, Time, Source, List, Remove
# -----------------------------------------------------------------------------

appendrc_init() {
    local filename="$1"
    if [[ -z "$filename" ]]; then
        echo "Usage: appendrc init <filename>"
        return 1
    fi
    local filepath="$APPENDRC_SRC_PATH/$filename"
    touch "$filepath"
    cat > "$filepath" <<- 'EOF'
	# [ -f "$HOME/.example_package/env" ] && "$HOME/.example_package/env"
	EOF
    "${EDITOR:-nano}" "$filepath"
}

# Add content directly to a file
appendrc_file_add() {
    local filename="$1"
    shift
    local content="$*"

    if [[ -z "$filename" || -z "$content" ]]; then
        echo "Usage: appendrc add <filename> <content>"
        return 1
    fi

    local filepath="$APPENDRC_SRC_PATH/$filename"
    echo "$content" > "$filepath"
    echo "Created $filename with provided content."
}

appendrc_time() {
    local time_file="$APPENDRC_PATH/appendrc_time.txt"
    local fast_file="$APPENDRC_PATH/appendrc_fast"
    rm -f "$time_file" "$fast_file"

    for file in "$APPENDRC_SRC_PATH"/*; do
        [ -e "$file" ] || continue
        local filename=$(basename "$file")
        local start_time=$(date +%s.%N)
        source "$file"
        local end_time=$(date +%s.%N)
        local elapsed_time=$(echo "$end_time - $start_time" | bc)
        echo "$filename,$elapsed_time" >> "$time_file"

        if (( $(echo "$elapsed_time < 1" | bc -l) )); then
            echo "source $file" >> "$fast_file"
        fi
    done

    echo "Timing results saved to $time_file"
    echo "Fast sourcables saved to $fast_file"
}

appendrc_source() {
    local fast=false
    if [[ "$1" == "--fast" ]]; then
        fast=true
    fi

    if $fast && [[ -f "$APPENDRC_PATH/appendrc_fast" ]]; then
        source "$APPENDRC_PATH/appendrc_fast"
    else
        for file in "$APPENDRC_SRC_PATH"/*; do
            [ -e "$file" ] || continue
            source "$file"
        done
    fi
}

appendrc_list() {
    echo "Files in $APPENDRC_SRC_PATH:"
    ls -1 "$APPENDRC_SRC_PATH"
}

appendrc_remove() {
    local filename="$1"
    if [[ -z "$filename" ]]; then
        echo "Usage: appendrc remove <filename>"
        return 1
    fi

    local filepath="$APPENDRC_SRC_PATH/$filename"
    if [[ ! -f "$filepath" ]]; then
        echo "File $filename does not exist."
        return 1
    fi
    rm "$filepath"
    echo "File $filename removed."
}

# -----------------------------------------------------------------------------
# PATH Module Logic (Updated with Check)
# -----------------------------------------------------------------------------

_appendrc_sync_path_file() {
    cat > "$APPENDRC_PATH_SOURCABLE" <<- 'EOF'
	# Auto-generated by appendrc path module. Do not edit manually.
	_arc_path_add() {
	    local p="$1"
	    if [ -d "$p" ]; then
	        case ":$PATH:" in
	            *":$p:"*) ;;             # Already in PATH
	            *) export PATH="$p:$PATH" ;; # Prepend
	        esac
	    fi
	}
	EOF

    if [[ -f "$APPENDRC_PATH_LIST" ]]; then
        while IFS= read -r p || [ -n "$p" ]; do
            [[ -z "$p" ]] && continue
            echo "_arc_path_add \"$p\"" >> "$APPENDRC_PATH_SOURCABLE"
        done < "$APPENDRC_PATH_LIST"
    fi
    echo "unset -f _arc_path_add" >> "$APPENDRC_PATH_SOURCABLE"
}

appendrc_path_manager() {
    local cmd="$1"
    local arg="$2"

    touch "$APPENDRC_PATH_LIST"

    case "$cmd" in
        add)
            if [[ -z "$arg" ]]; then
                echo "Usage: appendrc path add /path/to/dir"
                return 1
            fi
            local abs_path=$(realpath "$arg" 2>/dev/null || echo "$arg")
            
            if grep -Fxq "$abs_path" "$APPENDRC_PATH_LIST"; then
                echo "Path already exists in managed list."
            else
                echo "$abs_path" >> "$APPENDRC_PATH_LIST"
                _appendrc_sync_path_file
                echo "Added $abs_path. (Run 'appendrc source' to apply)"
            fi
            ;;
        
        remove|rm)
            if [[ -z "$arg" ]]; then
                echo "Usage: appendrc path remove /path/to/dir"
                return 1
            fi
            # Try to remove absolute version first, then exact string
            local abs_path=$(realpath "$arg" 2>/dev/null || echo "$arg")
            
            if grep -Fxq "$abs_path" "$APPENDRC_PATH_LIST"; then
                grep -vFx "$abs_path" "$APPENDRC_PATH_LIST" > "${APPENDRC_PATH_LIST}.tmp" && mv "${APPENDRC_PATH_LIST}.tmp" "$APPENDRC_PATH_LIST"
                _appendrc_sync_path_file
                echo "Removed $abs_path from persistent list."
            elif grep -Fxq "$arg" "$APPENDRC_PATH_LIST"; then
                 grep -vFx "$arg" "$APPENDRC_PATH_LIST" > "${APPENDRC_PATH_LIST}.tmp" && mv "${APPENDRC_PATH_LIST}.tmp" "$APPENDRC_PATH_LIST"
                _appendrc_sync_path_file
                echo "Removed $arg from persistent list."
            else
                echo "Path not found in managed list."
            fi
            ;;
        
        check)
            if [[ -z "$arg" ]]; then
                echo "Usage: appendrc path check /path/to/dir"
                return 1
            fi
            
            # 1. Resolve Target
            local target_abs
            target_abs=$(realpath "$arg" 2>/dev/null)
            
            echo "--- Path Diagnosis ---"
            if [[ -z "$target_abs" ]]; then
                echo "⚠️  Filesystem: Path does not exist on disk."
                target_abs=$(realpath -m "$arg" 2>/dev/null || echo "$arg") # normalize string anyway
                echo "   Checking for string: $target_abs"
            else
                echo "📂 Filesystem: Found at $target_abs"
            fi
            echo "----------------------"

            # 2. Check Managed List
            local found_managed="No"
            if [[ -f "$APPENDRC_PATH_LIST" ]]; then
                while IFS= read -r p || [ -n "$p" ]; do
                    [[ -z "$p" ]] && continue
                    # Resolve config entry to abs path to compare
                    local p_abs=$(realpath "$p" 2>/dev/null || echo "$p")
                    if [[ "$p_abs" == "$target_abs" ]]; then
                        found_managed="Yes"
                        break
                    fi
                done < "$APPENDRC_PATH_LIST"
            fi
            
            # 3. Check Active System PATH
            local found_active="No"
            IFS=':' read -ra PATH_DIRS <<< "$PATH"
            for dir in "${PATH_DIRS[@]}"; do
                local dir_abs=$(realpath "$dir" 2>/dev/null || echo "$dir")
                if [[ "$dir_abs" == "$target_abs" ]]; then
                    found_active="Yes"
                    break
                fi
            done

            # Report
            if [[ "$found_managed" == "Yes" ]]; then
                echo "✅ Managed: Included in appendrc path list."
            else
                echo "❌ Managed: Not in appendrc path list."
            fi

            if [[ "$found_active" == "Yes" ]]; then
                echo "✅ Active:  Currently present in \$PATH."
            else
                echo "❌ Active:  Not present in current \$PATH."
            fi
            ;;

        list|ls)
            echo "--- 📂 Managed Paths (via appendrc) ---"
            if [[ -s "$APPENDRC_PATH_LIST" ]]; then
                cat -n "$APPENDRC_PATH_LIST"
            else
                echo "  (None)"
            fi
            
            echo ""
            echo "--- 🖥️  System / Other Paths (active in \$PATH) ---"
            local managed_content=""
            if [[ -f "$APPENDRC_PATH_LIST" ]]; then
                managed_content=$(cat "$APPENDRC_PATH_LIST")
            fi
            IFS=':' read -ra PATH_DIRS <<< "$PATH"
            for dir in "${PATH_DIRS[@]}"; do
                if ! echo "$managed_content" | grep -Fqx "$dir"; then
                    echo "$dir"
                fi
            done | awk '!seen[$0]++'
            ;;
            
        sync)
            _appendrc_sync_path_file
            echo "Synced path sourcables."
            ;;
            
        *)
            echo "Usage: appendrc path {add|remove|check|list}"
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Main CLI
# -----------------------------------------------------------------------------

appendrc_help() {
    echo "Usage: appendrc <command> [options]"
    echo "General Commands:"
    echo "  init <filename>           Create file and open editor"
    echo "  add  <filename> <text>    Create file with specific content string"
    echo "  remove <filename>         Remove a file"
    echo "  list                      List files"
    echo "  source [--fast]           Source all files"
    echo "  time                      Measure source times"
    echo ""
    echo "Path Module:"
    echo "  path add <path>           Safely add a path (persisted)"
    echo "  path remove <path>        Remove a path (persisted)"
    echo "  path check <path>         Diagnose if a path is managed or active"
    echo "  path list                 List managed paths + system paths"
}

appendrc() {
    local cmd="$1"
    shift

    case "$cmd" in
        init)   appendrc_init "$@" ;;
        add)    appendrc_file_add "$@" ;;
        time)   appendrc_time ;;
        source) appendrc_source "$@" ;;
        list)   appendrc_list ;;
        remove) appendrc_remove "$@" ;;
        path)   appendrc_path_manager "$@" ;;
        -h|--help|*) appendrc_help ;;
    esac
}

# Execution Check
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    appendrc "$@"
fi

alias arc="appendrc"